resources:
  jobs:
    qrt_pipeline:
      name: "solvency_ii_qrt_pnc_pipeline"
      parameters:
        - name: catalog_name
          default: ${var.catalog_name}
        - name: schema_name
          default: ${var.schema_name}
        - name: reporting_date
          default: ${var.reporting_date}
        - name: entity_lei
          default: ${var.entity_lei}
        - name: entity_name
          default: ${var.entity_name}

      tasks:
        - task_key: setup
          notebook_task:
            notebook_path: ../src/notebooks/00_setup.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
          environment_key: default

        - task_key: generate_bronze_data
          depends_on:
            - task_key: setup
          notebook_task:
            notebook_path: ../src/notebooks/01_generate_bronze_data.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
              reporting_date: "{{job.parameters.reporting_date}}"
              entity_name: "{{job.parameters.entity_name}}"
          environment_key: default

        - task_key: silver_assets
          depends_on:
            - task_key: generate_bronze_data
          notebook_task:
            notebook_path: ../src/notebooks/02_silver_assets.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
          environment_key: default

        - task_key: silver_premiums_claims_expenses
          depends_on:
            - task_key: generate_bronze_data
          notebook_task:
            notebook_path: ../src/notebooks/03_silver_premiums_claims_expenses.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
          environment_key: default

        - task_key: silver_scr
          depends_on:
            - task_key: generate_bronze_data
          notebook_task:
            notebook_path: ../src/notebooks/04_silver_scr.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
          environment_key: default

        - task_key: gold_s0602
          depends_on:
            - task_key: silver_assets
          notebook_task:
            notebook_path: ../src/notebooks/05_gold_s0602.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
              reporting_date: "{{job.parameters.reporting_date}}"
              entity_lei: "{{job.parameters.entity_lei}}"
          environment_key: default

        - task_key: gold_s0501
          depends_on:
            - task_key: silver_premiums_claims_expenses
          notebook_task:
            notebook_path: ../src/notebooks/06_gold_s0501.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
              reporting_date: "{{job.parameters.reporting_date}}"
              entity_lei: "{{job.parameters.entity_lei}}"
          environment_key: default

        - task_key: gold_s2501
          depends_on:
            - task_key: silver_scr
          notebook_task:
            notebook_path: ../src/notebooks/07_gold_s2501.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
              reporting_date: "{{job.parameters.reporting_date}}"
              entity_lei: "{{job.parameters.entity_lei}}"
          environment_key: default

        - task_key: validation
          depends_on:
            - task_key: gold_s0602
            - task_key: gold_s0501
            - task_key: gold_s2501
          notebook_task:
            notebook_path: ../src/notebooks/08_validation.py
            base_parameters:
              catalog_name: "{{job.parameters.catalog_name}}"
              schema_name: "{{job.parameters.schema_name}}"
              reporting_date: "{{job.parameters.reporting_date}}"
          environment_key: default

      environments:
        - environment_key: default
          spec:
            client: "1"
            dependencies:
              - faker
              - numpy
              - pyyaml
