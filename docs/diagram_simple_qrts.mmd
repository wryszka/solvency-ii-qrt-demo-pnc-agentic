  classDef silverBox  fill:#e8e8ec,stroke:#8888aa,stroke-width:2px,color:#222244
  classDef goldBox    fill:#fff3b0,stroke:#c8a000,stroke-width:2px,color:#4a3800
  classDef govBox     fill:#ddeeff,stroke:#4477bb,stroke-width:2px,color:#1a2d55
