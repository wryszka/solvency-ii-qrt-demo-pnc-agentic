  classDef silverBox  fill:#e4e4ea,stroke:#7a7a9a,stroke-width:2px,color:#1e1e3a
  classDef goldBox    fill:#fff0a0,stroke:#b89800,stroke-width:2px,color:#3e3000
  classDef govBox     fill:#d4e8ff,stroke:#3a6aaa,stroke-width:2px,color:#0e2244
